# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore secret files
**/secret/
**/secrets/
**/*.pem
**/*.key

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore OS files
.DS_Store
Thumbs.db

# Local terraform files
*.tfvars
*.tfvars.json
.terraform.lock.hcl

# Local terraform state
terraform.tfstate
terraform.tfstate.backup

# Local terraform directories
.terraform/

# Scripts with sensitive data
add-gitlab-variables.sh
get-project-id.sh
fix-*.sh
*.sh

# Sensitive files
*.pem
*.key
*.secret
*.token

# Local configuration
.terraformrc
terraform.rc
